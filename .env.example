# ============================================================
# VARIABLES DE ENTORNO — Dra. Andrea WhatsApp AI
# Copia este archivo como .env y llena los valores
# NUNCA subas .env a GitHub
# ============================================================

# Puerto (Railway lo asigna automáticamente, no cambiar)
PORT=3000

# Secreto para autenticar el panel admin (crea uno aleatorio)
# Puedes generar uno en: https://randomkeygen.com/
ADMIN_SECRET=tu_secreto_super_seguro_aqui_cambiame

# OpenAI API Key (GPT-4o)
OPENAI_API_KEY=sk-...

# Supabase (tu proyecto existente)
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...

# URL del frontend admin (para CORS) - ej: https://draandreavargas.com
FRONTEND_URL=https://draandreavargas.com

# Modo: 'production' o 'development'  
NODE_ENV=production
